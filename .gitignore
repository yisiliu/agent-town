.DS_Store
_generated/
# Exempt the shared convex/ deployment _generated stubs — committed as
# placeholders so tests run on a fresh clone before the first
# `convex codegen`. Real codegen overwrites these at deploy time.
# Also un-ignore ai-town-fork/convex/_generated/ so the additivity
# check (which expects these files per UPSTREAM_FILES.lock) doesn't
# MISSING them on CI.
!convex/_generated/
!convex/_generated/**
!ai-town-fork/convex/_generated/
!ai-town-fork/convex/_generated/**
*.log
.claude/

# git worktrees (superpowers)
.worktrees/
